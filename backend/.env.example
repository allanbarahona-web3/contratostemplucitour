# ═══════════════════════════════════════════════════════════════════════════════
# .env.example - PLANTILLA DE VARIABLES DE ENTORNO
# 
# INSTRUCCIONES:
# 1. LOCAL: Copia esto a .env.local y llena con valores locales
# 2. PRODUCCIÓN (DO App): Copia solo las variables marcadas [REQUERIDO DO] a tu 
#    DigitalOcean App Platform
# ═══════════════════════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────────────────────────
# [REQUERIDO LOCAL + PRODUCCIÓN]
# ─────────────────────────────────────────────────────────────────────────────────
PORT=3001

# LOCAL: http://localhost:5179
# PRODUCCIÓN: https://tu-dominio-frontend.com
ALLOWED_ORIGIN=http://localhost:5179

# LOCAL: http://localhost:5179
# PRODUCCIÓN: https://tu-dominio-frontend.com
PUBLIC_APP_BASE_URL=https://contratos.lucitour.com

# ─────────────────────────────────────────────────────────────────────────────────
# [REQUERIDO DO APP] AUTENTICACIÓN JWT
# ⚠️  CRÍTICO: Generar valores seguros con:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ─────────────────────────────────────────────────────────────────────────────────
JWT_SECRET=replace-with-a-strong-secret-min-32-chars
JWT_EXPIRES_IN=12h
SIGNING_LINK_SECRET=replace-with-a-different-strong-secret-min-32-chars

# ─────────────────────────────────────────────────────────────────────────────────
# [REQUERIDO DO APP] BASE DE DATOS - DigitalOcean PostgreSQL
# Formato: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require&schema=schema
# ─────────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://doadmin:PASSWORD@host.db.ondigitalocean.com:25060/lucitour?sslmode=require&schema=contracts_temp

# ─────────────────────────────────────────────────────────────────────────────────
# [REQUERIDO DO APP] ALMACENAMIENTO - DigitalOcean Spaces
# Obtener keys del panel: Manage > Spaces > API Tokens
# ─────────────────────────────────────────────────────────────────────────────────
DO_SPACES_REGION=sfo3
DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
DO_SPACES_BUCKET=lucitouroperations
DO_SPACES_KEY=DO_XXXXXXXXXXXXXXXXXX
DO_SPACES_SECRET=yyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyyy

# ─────────────────────────────────────────────────────────────────────────────────
# [OPCIONAL] EMAIL - Resend.com (solo si envías emails)
# ─────────────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
CONTRACTS_FROM_EMAIL=contracts@tu-dominio.com
AUTH_FROM_EMAIL=noreply@tu-dominio.com

# ─────────────────────────────────────────────────────────────────────────────────
# [OPCIONAL] RATE LIMITING
# ─────────────────────────────────────────────────────────────────────────────────
RATE_LIMIT_TTL_MS=60000
RATE_LIMIT_MAX=120

# ─────────────────────────────────────────────────────────────────────────────────
# [SOLO LOCAL] PUPPETEER / PDF GENERATION
# ⚠️  NO INCLUYAS EN DO APP - Puppeteer descarga automáticamente Chromium
# ─────────────────────────────────────────────────────────────────────────────────
# LOCAL solamente:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PUPPETEER_CACHE_DIR=.cache/puppeteer
PUPPETEER_DISABLE_SANDBOX=true
PDF_RENDER_LAUNCH_TIMEOUT_MS=30000
PDF_RENDER_CONTENT_TIMEOUT_MS=45000
PDF_RENDER_PDF_TIMEOUT_MS=45000

# ─────────────────────────────────────────────────────────────────────────────────
# [SOLO LOCAL] SEED - Usuario inicial para testing
# ─────────────────────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@lucitour.com
SEED_ADMIN_PASSWORD=Cambiar123!
SEED_ADMIN_NAME=Administrador Lucitour

# ═══════════════════════════════════════════════════════════════════════════════
# CHECKLIST - VARIABLES PARA DO APP (DigitalOcean App Platform)
# ═══════════════════════════════════════════════════════════════════════════════
#
# COPIAR ESTAS VARIABLES A DO APP:
# 
# ✅ PORT=3001
# ✅ ALLOWED_ORIGIN=https://tu-dominio.com
# ✅ PUBLIC_APP_BASE_URL=https://tu-dominio.com
# ✅ JWT_SECRET=<valor-seguro>
# ✅ SIGNING_LINK_SECRET=<valor-seguro>
# ✅ DATABASE_URL=postgresql://...
# ✅ DO_SPACES_REGION=sfo3
# ✅ DO_SPACES_ENDPOINT=https://sfo3.digitaloceanspaces.com
# ✅ DO_SPACES_BUCKET=lucitouroperations
# ✅ DO_SPACES_KEY=DO_...
# ✅ DO_SPACES_SECRET=...
# ✅ RATE_LIMIT_TTL_MS=60000
# ✅ RATE_LIMIT_MAX=120
# ✅ RESEND_API_KEY= (si envías emails)
# ✅ CONTRACTS_FROM_EMAIL= (si envías emails)
# ✅ AUTH_FROM_EMAIL= (si envías emails)
#
# NO COPIAR A DO APP (solo local):
# ❌ PUPPETEER_EXECUTABLE_PATH - No necesario, Puppeteer lo descarga
# ❌ SEED_ADMIN_* - Solo para testing local
#
# ═══════════════════════════════════════════════════════════════════════════════
