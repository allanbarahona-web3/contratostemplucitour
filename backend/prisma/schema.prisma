generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  isActive     Boolean  @default(true)
  activeJti    String?
  activeAt     DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ContractNumber {
  id              String   @id @default(cuid())
  number          String   @unique
  createdByUserId String
  createdByEmail  String
  createdByName   String
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model Contract {
  id                String             @id @default(cuid())
  contractNumber    String             @unique
  clientId          String
  destination       String
  status            String             @default("PENDING_SIGNATURE")
  generatedByUserId String
  generatedByEmail  String
  generatedByName   String
  issuedAt          DateTime?
  startDate         DateTime?
  endDate           DateTime?
  payload           Json
  pdfObjectKey      String
  pdfFileName       String
  pdfMimeType       String
  pdfSize           Int
  signedPdfObjectKey String?
  signedPdfFileName  String?
  signedPdfMimeType  String?
  signedPdfSize      Int?
  signedByName          String?
  signedAt              DateTime?
  signedClientIp        String?
  signedUserAgent       String?
  htmlObjectKey         String?
  viewedAt              DateTime?
  cancelledAt           DateTime?
  signaturePngObjectKey String?
  createdAt             DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  documents         ContractDocument[]
  signatureEvents   ContractSignatureEvent[]
  usedTokens        ContractUsedToken[]

  @@index([clientId])
  @@index([createdAt])
}

model Client {
  id                    String     @id @default(cuid())
  fullName              String
  idNumber              String     @unique
  email                 String
  phone                 String?
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  contracts             Contract[]

  @@index([fullName])
  @@index([email])
}

model ContractDocument {
  id               String   @id @default(cuid())
  contractId       String
  kind             String?
  originalFileName String
  objectKey        String   @unique
  mimeType         String
  size             Int
  createdAt        DateTime @default(now())
  contract         Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([createdAt])
}

// One row per completed signature event — immutable audit log.
// Captures who signed, when, from where, and the resulting PDF state.
model ContractSignatureEvent {
  id              String   @id @default(cuid())
  contractId      String
  signerKey       String   // "client" | "companion-0" etc.
  signerRole      String   // "CLIENTE" | "ACOMPANANTE"
  signerName      String
  signedAt        DateTime
  signedClientIp  String?
  signedUserAgent String?
  signaturePngKey String?  // Spaces object key of the captured PNG
  signedPdfKey    String?  // Spaces object key of the PDF after this signer
  signedPdfBytes  Int?
  signedPdfSha256 String?  // hex SHA-256 of the signed PDF at this step
  tokenHash       String?  // SHA-256 of the token used (for cross-reference)
  createdAt       DateTime @default(now())
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([signedAt])
}

// One row per spent signing token — tokenHash has a UNIQUE constraint so
// the DB enforces atomicity; two concurrent requests for the same token
// cannot both succeed.
model ContractUsedToken {
  id         String   @id @default(cuid())
  contractId String
  tokenHash  String   @unique  // SHA-256 of the raw token string
  signerKey  String
  usedAt     DateTime @default(now())
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}
