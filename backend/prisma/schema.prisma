generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  fullName           String
  role               String   @default("AGENT")
  passwordHash       String
  isActive           Boolean  @default(true)
  mustChangePassword Boolean  @default(false)
  activeJti          String?
  activeAt           DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  passwordResetTokens PasswordResetToken[]
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("password_reset_token")
}

model ContractNumber {
  id              String   @id @default(cuid())
  number          String   @unique
  createdByUserId String
  createdByEmail  String
  createdByName   String
  createdAt       DateTime @default(now())

  @@index([createdAt])
}

model Contract {
  id                String             @id @default(cuid())
  contractNumber    String             @unique
  paymentReference  String             @unique
  clientId          String
  destination       String
  status            String             @default("PENDING_SIGNATURE")
  generatedByUserId String
  generatedByEmail  String
  generatedByName   String
  issuedAt          DateTime?
  startDate         DateTime?
  endDate           DateTime?
  payload           Json
  pdfObjectKey      String
  pdfFileName       String
  pdfMimeType       String
  pdfSize           Int
  signedPdfObjectKey String?
  signedPdfFileName  String?
  signedPdfMimeType  String?
  signedPdfSize      Int?
  signedByName          String?
  signedAt              DateTime?
  signedClientIp        String?
  signedUserAgent       String?
  htmlObjectKey         String?
  viewedAt              DateTime?
  cancelledAt           DateTime?
  signaturePngObjectKey String?
  createdAt             DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  client            Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  documents         ContractDocument[]
  signatureEvents   ContractSignatureEvent[]
  usedTokens        ContractUsedToken[]
  billingInvoice    BillingInvoice?
  billingPayments   BillingPayment[]
  billingReceipts   BillingReceipt[]
  billingCreditNotes BillingCreditNote[]

  @@index([clientId])
  @@index([createdAt])
}

model ContractDraft {
  id                String   @id @default(cuid())
  contractNumber    String   @unique
  status            String   @default("DRAFT")
  clientFullName    String?
  clientIdNumber    String?
  clientEmail       String?
  clientPhone       String?
  destination       String?
  payload           Json
  generatedByUserId String
  generatedByEmail  String
  generatedByName   String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([generatedByUserId])
  @@index([createdAt])
}

model Client {
  id                    String     @id @default(cuid())
  fullName              String
  idNumber              String     @unique
  email                 String
  phone                 String?
  emergencyContactName  String?
  emergencyContactPhone String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  contracts             Contract[]
  billingInvoices       BillingInvoice[]
  billingClientBalance  BillingClientBalance?

  @@index([fullName])
  @@index([email])
}

model ContractDocument {
  id               String   @id @default(cuid())
  contractId       String
  kind             String?
  originalFileName String
  objectKey        String   @unique
  mimeType         String
  size             Int
  createdAt        DateTime @default(now())
  contract         Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([createdAt])
}

// One row per completed signature event — immutable audit log.
// Captures who signed, when, from where, and the resulting PDF state.
model ContractSignatureEvent {
  id              String   @id @default(cuid())
  contractId      String
  signerKey       String   // "client" | "companion-0" etc.
  signerRole      String   // "CLIENTE" | "ACOMPANANTE"
  signerName      String
  signedAt        DateTime
  signedClientIp  String?
  signedUserAgent String?
  signaturePngKey String?  // Spaces object key of the captured PNG
  signedPdfKey    String?  // Spaces object key of the PDF after this signer
  signedPdfBytes  Int?
  signedPdfSha256 String?  // hex SHA-256 of the signed PDF at this step
  tokenHash       String?  // SHA-256 of the token used (for cross-reference)
  createdAt       DateTime @default(now())
  contract        Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
  @@index([signedAt])
}

// One row per spent signing token — tokenHash has a UNIQUE constraint so
// the DB enforces atomicity; two concurrent requests for the same token
// cannot both succeed.
model ContractUsedToken {
  id         String   @id @default(cuid())
  contractId String
  tokenHash  String   @unique  // SHA-256 of the raw token string
  signerKey  String
  usedAt     DateTime @default(now())
  contract   Contract @relation(fields: [contractId], references: [id], onDelete: Cascade)

  @@index([contractId])
}

model BillingInvoice {
  id                String   @id @default(cuid())
  contractId        String   @unique
  clientId          String
  contractNumber    String   @unique
  invoiceNumber     String   @unique
  currency          String   @default("CRC")
  totalAmount       Decimal  @db.Decimal(14, 2)
  verifiedAmount    Decimal  @db.Decimal(14, 2)
  pendingAmount     Decimal  @db.Decimal(14, 2)
  balanceAmount     Decimal  @db.Decimal(14, 2)
  status            String   @default("FACTURA_EMITIDA")
  issuedAt          DateTime @default(now())
  paymentDueDate    DateTime?
  closedAt          DateTime?
  objectKeyPdf      String?
  pdfFileName       String?
  pdfMimeType       String?
  pdfSize           Int?
  createdByUserId   String
  createdByName     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  contract          Contract @relation(fields: [contractId], references: [id], onDelete: Restrict)
  client            Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  payments          BillingPayment[]
  receipts          BillingReceipt[]
  creditNotes       BillingCreditNote[]

  @@index([clientId])
  @@index([status])
  @@index([createdAt])
}

model BillingPayment {
  id                String   @id @default(cuid())
  invoiceId         String
  contractId        String
  type              String   @default("OTHER")
  amount            Decimal  @db.Decimal(14, 2)
  currency          String   @default("CRC")
  reportedAt        DateTime @default(now())
  status            String   @default("ABONO_REPORTADO")
  bankReference     String?
  payerName         String?
  notes             String?
  // Nuevos campos para procesamiento de comprobantes
  originBank        String?  // Banco desde donde se hizo el pago
  destinationBank   String?  // Banco destino (derivado de la cuenta)
  destinationAccountId String? // Referencia a CompanyBankAccount
  paymentCode       String?  // Código único de pago (LUC-XXXXX)
  receiptDate       DateTime? // Fecha del comprobante (puede diferir de reportedAt)
  verifiedAt        DateTime?
  verifiedByUserId  String?
  verifiedByName    String?
  rejectionReason   String?
  createdByUserId   String
  createdByName     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  invoice           BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  contract          Contract       @relation(fields: [contractId], references: [id], onDelete: Restrict)
  destinationAccount CompanyBankAccount? @relation(fields: [destinationAccountId], references: [id], onDelete: Restrict)
  attachments       BillingPaymentAttachment[]
  receipt           BillingReceipt?
  receiptImage      PaymentReceiptImage?

  @@index([invoiceId])
  @@index([contractId])
  @@index([destinationAccountId])
  @@index([paymentCode])
  @@index([status])
  @@index([reportedAt])
}

model BillingPaymentAttachment {
  id               String   @id @default(cuid())
  paymentId        String
  objectKey        String   @unique
  originalFileName String
  mimeType         String
  size             Int
  createdAt        DateTime @default(now())
  payment          BillingPayment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([paymentId])
  @@index([createdAt])
}

model BillingReceipt {
  id                String   @id @default(cuid())
  paymentId         String   @unique
  invoiceId         String
  contractId        String
  contractNumber    String
  receiptNumber     String   @unique
  amount            Decimal  @db.Decimal(14, 2)
  issuedAt          DateTime @default(now())
  issuedByUserId    String
  issuedByName      String
  approvedAt        DateTime?
  approvedByUserId  String?
  approvedByName    String?
  sentAt            DateTime?
  sentToEmail       String?
  objectKeyPdf      String?
  status            String   @default("RECIBO_PENDIENTE_VERIFICACION")
  createdAt         DateTime @default(now())
  payment           BillingPayment @relation(fields: [paymentId], references: [id], onDelete: Restrict)
  invoice           BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  contract          Contract       @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([contractId])
  @@index([status])
  @@index([issuedAt])
}

model BillingCreditNote {
  id                 String   @id @default(cuid())
  creditNoteNumber   String   @unique
  contractId         String
  invoiceId          String
  contractNumber     String
  reason             String
  amount             Decimal  @db.Decimal(14, 2)
  status             String   @default("NC_EMITIDA")
  sourceDocumentType String
  sourceDocumentId   String
  issuedAt           DateTime @default(now())
  issuedByUserId     String
  issuedByName       String
  appliedAt          DateTime?
  appliedByUserId    String?
  appliedByName      String?
  objectKeyPdf       String?
  createdAt          DateTime @default(now())
  invoice            BillingInvoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  contract           Contract       @relation(fields: [contractId], references: [id], onDelete: Restrict)

  @@index([invoiceId])
  @@index([contractId])
  @@index([status])
  @@index([issuedAt])
}

model BillingClientBalance {
  id                   String   @id @default(cuid())
  clientId             String   @unique
  availableCreditAmount Decimal @db.Decimal(14, 2)
  currency             String   @default("CRC")
  updatedAt            DateTime @updatedAt
  client               Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
}

model BillingAuditLog {
  id          String   @id @default(cuid())
  entityType  String
  entityId    String
  action      String
  actorUserId String
  actorName   String
  beforeJson  Json?
  afterJson   Json?
  sourceIp    String?
  userAgent   String?
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([actorUserId])
  @@index([createdAt])
}

model ExchangeRate {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  buyRate     Decimal  @db.Decimal(10, 4)
  sellRate    Decimal  @db.Decimal(10, 4)
  source      String   @default("MANUAL")
  setByUserId String
  setByName   String
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([date])
  @@index([date])
  @@index([setByUserId])
}

// Cuentas bancarias de la empresa para recibir pagos
model CompanyBankAccount {
  id                String   @id @default(cuid())
  bankName          String   // BAC, BCR, Promerica, etc.
  accountNumber     String   @unique // Número de cuenta o IBAN
  accountType       String   // "CUENTA_CORRIENTE", "CUENTA_AHORRO"
  currency          String   // "CRC", "USD"
  sinpeNumber       String?  // Número SINPE móvil (opcional)
  accountHolderName String   // Nombre del titular (Empresa)
  companyName       String   @default("Viajes Alma Nova") // Nombre de la empresa (ej: "Viajes Alma Nova", "Lucitours")
  isActive          Boolean  @default(true)
  notes             String?
  createdByUserId   String
  createdByName     String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  payments          BillingPayment[]

  @@index([bankName])
  @@index([currency])
  @@index([isActive])
  @@index([companyName])
  @@index([createdAt])
}

// Imágenes de comprobantes procesados con Vision AI
model PaymentReceiptImage {
  id                      String   @id @default(cuid())
  paymentId               String?  @unique
  objectKey               String   @unique // Spaces/S3 key
  originalFileName        String
  mimeType                String
  size                    Int
  // Datos extraídos por Vision AI
  extractedData           Json     // Raw JSON de OpenAI
  extractedAmount         Decimal? @db.Decimal(14, 2)
  extractedCurrency       String?
  extractedDate           DateTime?
  extractedReference      String?
  extractedOriginBank     String?
  extractedDestinationBank String?
  extractedDestinationAccount String?
  extractedPayerName      String?
  extractedPaymentCode    String?  // Código único de pago
  extractedNotes          String?  // Resto del detalle
  confidenceScore         Decimal? @db.Decimal(5, 4) // 0.0000 - 1.0000
  processingStatus        String   @default("PENDING") // PENDING, PROCESSED, ERROR
  processingError         String?
  processedAt             DateTime?
  uploadedByUserId        String
  uploadedByName          String
  createdAt               DateTime @default(now())
  payment                 BillingPayment? @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([paymentId])
  @@index([processingStatus])
  @@index([createdAt])
}
